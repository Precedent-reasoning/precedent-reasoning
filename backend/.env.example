# Required: Anthropic API key for Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Tavily API key for web search (https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Comma-separated list of allowed CORS origins (default: http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
